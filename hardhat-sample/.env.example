# Mantle Network RPC URLs
# Mantle Sepolia Testnet (chainId: 5003)
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz

# Mantle Mainnet (chainId: 5000)
MANTLE_MAINNET_RPC_URL=https://rpc.mantle.xyz

# デプロイヤーの秘密鍵（先頭の0xは不要）
# 注意: 本番環境では絶対にGitにコミットしないこと
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Mantle Explorer API Key（コントラクト検証用）
# https://explorer.mantle.xyz でAPIキーを取得
MANTLE_EXPLORER_API_KEY=your_explorer_api_key_here
